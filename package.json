{
  "name": "my-buddy",
  "version": "3.0.0-alpha.0",
  "description": "Safe, customizable ASCII buddy for Claude Code statusLine — no binary patching",
  "type": "module",
  "bin": {
    "my-buddy": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "assets/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "dev": "bun src/cli.ts",
    "dev:build": "pnpm run build && bun dist/cli.js",
    "dev:node": "pnpm run build && node dist/cli.js",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cpaczek/any-buddy"
  },
  "keywords": [
    "claude",
    "claude-code",
    "buddy",
    "companion",
    "pet",
    "customizer",
    "cli"
  ],
  "author": "",
  "license": "WTFPL",
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "@opentui/core": "^0.1.95",
    "chalk": "^5.3.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/node": "^20",
    "@vitest/coverage-v8": "^3",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.7",
    "typescript-eslint": "^8",
    "vitest": "^3"
  }
}
